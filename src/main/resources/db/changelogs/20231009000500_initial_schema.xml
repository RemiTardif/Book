<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <changeSet id="20231009000500" author="demo">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="book"/>
            </not>
        </preConditions>
        <createTable tableName="book">
            <column name="titre" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="auteur" type="varchar">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20231009000501" author="demo">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="book" columnName="id"/>
            </not>
        </preConditions>
        <addColumn tableName="book">
            <column name="id" type="varchar">
                <constraints nullable="false" primaryKey="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="20231009000503" author="demo">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="book" columnName="reserved"/>
            </not>
        </preConditions>
        <addColumn tableName="book">
            <column name="reserved" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>